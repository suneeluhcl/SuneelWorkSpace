# Adwi Workspace .gitignore — auto-managed by adwi /backup-enable
# NEVER commit secrets, credentials, or runtime data.

# ── Secrets and credentials (CRITICAL) ──────────────────────────────
secrets/
**/.env
**/secrets.local.env
**/*token*
**/*secret*
**/*credentials*
**/*.pem
**/*.p12
**/*.pfx
**/*.key
**/id_rsa
**/id_ed25519
**/.netrc
**/.npmrc
**/gmail-token.json
**/google-token.json

# ── Python ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/

# ── Node ────────────────────────────────────────────────────────────
node_modules/
.npm/
*.lock

# ── macOS ───────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db

# ── Docker runtime data (large, contains runtime secrets) ───────────
local-ai-stack/open-webui-data/
local-ai-stack/n8n-data/
local-ai-stack/searxng-data/
local-ai-stack/qdrant-data/
local-ai-stack/data/
mcp-servers/qdrant-data/

# ── Home Assistant runtime data ──────────────────────────────────────
local-ai-stack/homeassistant-data/

# ── High-volume log directories ──────────────────────────────────────
notes/clipboard-command-logs/
notes/open-webui-sync-logs/
notes/adwi-action-logs/
notes/adwi-repair-logs/backups/
notes/daily-status/
notes/maintenance-logs/
notes/self-heal-logs/
notes/secrets-logs/

# ── AI model files (large binaries) ─────────────────────────────────
*.gguf
*.bin
*.safetensors
*.onnx
*.pt
*.pth
*.model
models/
ollama-blobs/

# ── IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Runtime state files ──────────────────────────────────────────────
*.pid
local-command-api/api.pid
mcp-servers/workspace.db
adwi/memory.db
adwi/knowledge.db
adwi/rag-db/
bin/*.backup.*

# ── Misc ─────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
.env.local

# ── Config env (API tokens) ──
config/.env
# config/.env.example is intentionally tracked (safe template, no real values)

# ── Obsidian vault runtime files ──
obsidian-vault/.obsidian/workspace.json
obsidian-vault/.obsidian/workspace-mobile.json

# ── Eval session result directories (large/regenerable) ──────────────────────
# Tracked: MASTER_REPORT_v2.md, fix_backlog_v2.json, *.py harnesses
# Ignored: large raw result dirs (thousands of jsonl rows, regenerable)
logs/simeval/large-*/
logs/simeval/large-p2-*/
logs/simeval/session-*/
logs/simeval/__pycache__/
logs/simlab/

# ── Nightly eval session artifacts (large/regenerable) ───────────────────────
# Tracked: 00_morning_brief.md, 01_repair_backlog.md (markdown reports)
# Ignored: raw JSONL results, per-session dirs (too large, fully regenerable)
logs/nightly/[0-9]*/nlu_results.jsonl
logs/nightly/[0-9]*/scenarios.jsonl
logs/nightly/[0-9]*/phoenix_upload.jsonl
logs/nightly/__pycache__/
logs/nightly-eval.stdout.log
logs/nightly-eval.stderr.log
logs/nightly-eval.lock

# ── Eval tool generated output (not committed) ───────────────────────────────
eval/scenarios/generated/
eval/promptfoo/results/
eval/playwright/results/
eval/playwright/test-results/
eval/k6/results/
eval/promptfoo/node_modules/
eval/playwright/node_modules/
eval/__pycache__/
eval/nightly/__pycache__/
eval/giskard/__pycache__/
eval/deepeval/__pycache__/
eval/deepeval/.deepeval/

# ── Langfuse (optional, runtime data) ────────────────────────────────────────
# config/langfuse/docker-compose.langfuse.yml is tracked (template)
# Runtime DB and credentials are not
langfuse_db_data/

# ── config/eval/nightly.local.yaml — machine-local overrides ─────────────────
config/eval/nightly.local.yaml
