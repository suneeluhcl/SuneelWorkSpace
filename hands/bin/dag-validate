#!/usr/bin/env python3
"""P3.5 — Validate a pipeline YAML. Thin CLI over heart/orchestrator/dag/dag_validator.py
(single source of truth — dag-run imports the same module)."""

import os
import sys
from pathlib import Path

ROOT = Path(os.environ.get("SUNEEL_WORKSPACE", Path.home() / "SuneelWorkSpace")).resolve()
sys.path.insert(0, str(ROOT / "heart" / "orchestrator" / "dag"))

from dag_validator import validate, yaml  # noqa: E402


def main() -> None:
    if len(sys.argv) < 2:
        print("Usage: dag-validate <pipeline.yaml>")
        sys.exit(1)
    ok, errors = validate(sys.argv[1])
    if ok:
        pipeline = yaml.safe_load(Path(sys.argv[1]).read_text())
        steps = pipeline.get("steps", [])
        print(f"PASS — {len(steps)} steps validated: {sys.argv[1]}")
    else:
        print(f"FAIL — {len(errors)} error(s):")
        for e in errors:
            print(f"  • {e}")
        sys.exit(1)


if __name__ == "__main__":
    main()
