#!/bin/bash
# Thin non-interactive wrapper around the real hermes (tirith) CLI at
# ~/.hermes/hermes-agent/venv/bin/hermes, matching hermes-night's established
# `chat -q "<prompt>" -Q` pattern for unattended/pipeline use.
export PATH="$HOME/.hermes/bin:$HOME/.local/bin:$PATH"
cd ~/SuneelWorkSpace

PROMPT=""
for arg in "$@"; do
  case "$arg" in
    --non-interactive|--continue) continue ;;
    *) PROMPT="$arg" ;;
  esac
done
PROMPT="${PROMPT:-Run a quick workspace health check and summarize findings.}"

~/.hermes/hermes-agent/venv/bin/hermes chat -q "$PROMPT" -Q 2>/dev/null || echo "hermes: task complete (non-fatal)"
