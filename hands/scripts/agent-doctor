#!/bin/sh
set -eu

ROOT="${SUNEEL_WORKSPACE:-$HOME/SuneelWorkSpace}"
. "$ROOT/hands/automation/maintenance/common.sh"
ensure_core_dirs

LAUNCHD_LOADED=false
if command -v launchctl >/dev/null 2>&1; then
  if launchctl print "gui/$(id -u)/$LAUNCHD_LABEL" >/dev/null 2>&1; then
    LAUNCHD_LOADED=true
  fi
fi
export LAUNCHD_LOADED

python3 - "$ROOT" "$CANON" "$HEALTH_JSON" "$LAUNCHD_LABEL" "$LAUNCHD_USER_PLIST" <<'PY'
import json, os, pathlib, shutil, stat, sys
from datetime import datetime

root = pathlib.Path(sys.argv[1])
canon = pathlib.Path(sys.argv[2])
health_path = pathlib.Path(sys.argv[3])
launchd_label = sys.argv[4]
launchd_user_plist = pathlib.Path(sys.argv[5])
home = pathlib.Path.home()
issues = []
suggestions = []

def issue(severity, code, message, path=None):
    item = {"severity": severity, "code": code, "message": message}
    if path:
        item["path"] = str(path)
    issues.append(item)

required_dirs = [
    "brain", "heart", "eyes", "ears", "nervous", "skeleton",
    "blood", "hands", "mouth", "dna", "lab", "spine",
    "projects", ".agent-backups",
]
required_files = [
    "skeleton/rules/AGENT_SYSTEM.md",
    "skeleton/rules/IDENTITY.md",
    "skeleton/rules/WORKFLOW_RULES.md",
    "skeleton/rules/SAFETY_BOUNDARIES.md",
    "skeleton/rules/STARTUP_CHECKLIST.md",
    "brain/memory/MEMORY.md",
    "brain/memory/DECISIONS.md",
    "brain/memory/SESSION_HANDOFF.md",
    "brain/memory/NOTES.md",
    "heart/tasks/ACTIVE_TASKS.md",
    "heart/tasks/COMPLETED_TASKS.md",
    "heart/tasks/TASK_QUEUE.md",
    "blood/logs/SESSION_LOG.md",
    "blood/logs/MAINTENANCE_LOG.md",
    "spine/state/CURRENT_STATE.json",
    "spine/state/WORKSPACE_HEALTH.json",
    "spine/state/INDEX.json",
    "README.md", ".gitignore",
]
scripts = [
    "agent-status", "agent-start", "agent-finish", "agent-doctor", "agent-repair",
    "agent-maintain", "agent-autoclose", "use-codex", "use-claude", "workspace-context",
    "workspace-backup", "workspace-index", "workspace-report", "workspace-changes", "workflow-audit", "gstack-create",
]
autolab_scripts = []
entrypoints = [
    root / "AGENTS.md",
    root / "CLAUDE.md",
    home / ".codex" / "AGENTS.md",
    home / ".claude" / "CLAUDE.md",
]
for d in required_dirs:
    if not (root / d).is_dir():
        issue("error", "missing_dir", f"Required directory is missing: {d}", root / d)
for f in required_files:
    if not (root / f).exists():
        issue("error", "missing_file", f"Required file is missing: {f}", root / f)
for p in entrypoints:
    if not p.exists() and not p.is_symlink():
        issue("error", "missing_entrypoint", "Agent entrypoint is missing", p)
    elif p.is_symlink():
        target = pathlib.Path(os.readlink(p))
        if target != canon:
            issue("error", "wrong_symlink", f"Entrypoint points to {target}, expected {canon}", p)
    else:
        text = p.read_text(errors="ignore")
        if str(canon) not in text and "~/SuneelWorkSpace/agent-system/shared/AGENT_SYSTEM.md" not in text:
            issue("warning", "wrapper_drift", "Entrypoint is not aligned with canonical instructions", p)
for f in ["CURRENT_STATE.json", "WORKSPACE_HEALTH.json", "INDEX.json"]:
    p = root / "spine/state" / f
    try:
        json.loads(p.read_text())
    except Exception as exc:
        issue("error", "malformed_json", f"{f} is not valid JSON: {exc}", p)
for f in ["frontier.json", "latest_eval.json", "loop_status.json"]:
    p = root / "lab/autolab/state" / f
    if p.exists():
        try:
            json.loads(p.read_text())
        except Exception as exc:
            issue("error", "malformed_json", f"lab/autolab/state/{f} is not valid JSON: {exc}", p)
handoff = root / "brain/memory/SESSION_HANDOFF.md"
if handoff.exists():
    text = handoff.read_text(errors="ignore").strip()
    if len(text) < 80:
        issue("warning", "empty_handoff", "SESSION_HANDOFF.md is empty or too short to be useful", handoff)
    else:
        try:
            age_hours = (__import__("time").time() - handoff.stat().st_mtime) / 3600
            if age_hours > 168:
                issue("info", "stale_handoff", "SESSION_HANDOFF.md has not changed in over 7 days", handoff)
        except Exception:
            pass
for s in scripts:
    p = root / "bin" / s
    if not p.exists():
        issue("error", "missing_script", f"Script is missing: {s}", p)
    elif not os.access(p, os.X_OK):
        issue("warning", "not_executable", f"Script is not executable: {s}", p)
for s in autolab_scripts:
    p = root / "autolab/scripts" / s
    if not p.exists():
        issue("warning", "missing_autolab_script", f"Autolab script is missing: {s}", p)
    elif not os.access(p, os.X_OK):
        issue("warning", "autolab_not_executable", f"Autolab script is not executable: {s}", p)
zshrc = home / ".zshrc"
if zshrc.exists():
    text = zshrc.read_text(errors="ignore")
    for alias in ["swroot", "swstatus", "swdoctor", "swrepair", "swcodex", "swclaude"]:
        if f"alias {alias}=" not in text and f"function {alias}" not in text:
            issue("info", "missing_alias", f"Shell helper missing: {alias}", zshrc)
else:
    issue("info", "missing_shell_config", "~/.zshrc not found", zshrc)
plist_present = launchd_user_plist.exists() or launchd_user_plist.is_symlink()
if not plist_present:
    issue("info", "launchd_not_configured", "launchd maintenance plist is not installed", launchd_user_plist)
if launchd_user_plist.is_symlink() and not launchd_user_plist.exists():
    issue("error", "launchd_broken_symlink", "launchd maintenance plist is a broken symlink (target missing)", launchd_user_plist)
loaded = os.environ.get("LAUNCHD_LOADED") == "true"
if plist_present and not loaded:
    issue("warning", "launchd_not_loaded", "launchd maintenance plist exists but is not loaded", launchd_user_plist)
# 5. Check GStack integrity
gverify = root / "bin" / "gstack-verify"
if gverify.exists():
    try:
        import subprocess
        gv_res = subprocess.run([sys.executable, str(gverify), "--json"], capture_output=True, text=True, timeout=10)
        gv_data = json.loads(gv_res.stdout)
        if gv_data.get("status") != "ok":
            for i_msg in gv_data.get("issues", ["unknown drift"]):
                issue("warning", "gstack_drift", f"GStack: {i_msg}", gverify)
    except Exception as exc:
        issue("warning", "gstack_check_failed", f"Failed to run gstack-verify: {exc}", gverify)

# 6. Check Headroom proxy status
import socket
s_headroom = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s_headroom.settimeout(2)
try:
    s_headroom.connect(("127.0.0.1", 8787))
    s_headroom.close()
except Exception:
    issue("warning", "headroom_down", "Headroom proxy is not running on port 8787 — context compression is inactive")
if not shutil.which("codex"):
    issue("info", "codex_not_on_path", "codex CLI is not on PATH")
if not shutil.which("claude"):
    issue("info", "claude_not_on_path", "claude CLI is not on PATH")
# 7. Check for duplicated/misplaced files and scripts
dupes = []
misplaced_scripts = []
misplaced_configs = []
non_symlink_bin = []

core_runner_files = {
    "agent-autoclose", "agent-doctor", "agent-finish", "agent-maintain",
    "agent-repair", "agent-start", "agent-status", "agent-test-loop",
    "comms-doctor", "comms-permissions-check", "comms-report", "comms-status",
    "context-reset", "gstack-create", "gstack-repair", "gstack-verify",
    "imessage-recent", "imessage-search", "imessage-send-draft", "imessage-status",
    "imsg-draft", "imsg-recent", "imsg-search", "imsg-send-confirmed",
    "install-imessage-plugin", "mail-draft-reply", "mail-recent", "mail-search",
    "mail-status", "use-claude", "use-claude-imessage", "use-codex",
    "use-gemini", "use-opencode", "use-opencode-gemini", "workflow-audit",
    "workspace-backup", "workspace-changes", "workspace-context", "workspace-index",
    "workspace-report", "anticipate", "idea-run", "idea-start", "identity-accept",
    "identity-adjust", "identity-reject", "improve-system", "next", "system-audit",
    "system-capabilities", "system-gaps", "system-recommend", "duplication-guard",
    # Phase 4: Multi-agent mesh
    "mesh-status", "mesh-assign", "mesh-monitor-start", "mesh-monitor-stop",
    # Phase 5: MCP connectors
    "ollama-mcp", "arxiv-mcp", "docker-mcp", "jupyter-mcp",
    # Phase 6: Knowledge graph
    "brain-graph-build", "brain-graph-query", "brain-graph-orphans",
    # Phase 9: API gateway
    "gateway-start", "gateway-stop", "gateway-status", "gateway-token",
    # Phase 10: Fixes
    "evolution-trend", "workspace-ci", "build-training-data", "mcp-autodiscover",
    # Other core scripts
    "daily-evolve", "integrity-guard", "mcp-reindex", "mcp-status",
    "prompt-eval", "workflow-analyze", "workspace-dashboard",
}


subsystem_dirs = {
    "brain", "heart", "eyes", "ears", "nervous", "skeleton",
    "blood", "hands", "mouth", "dna", "lab", "spine"
}


for p in root.rglob("*"):
    # Skip folders
    if not p.is_file() and not p.is_symlink():
        continue
        
    try:
        parts = p.relative_to(root).parts
    except ValueError:
        continue
        
    if not parts:
        continue
        
    top_dir = parts[0]
    filename = parts[-1]
    
    # Skip standard folders
    if any(k in parts for k in (".git", ".agent-backups", "__pycache__", "node_modules", "snapshots", ".hf_cache", "chroma_store", ".venv", "venv", "env", ".env")):
        continue
        
    # Check duplicate instruction files
    if filename in {"AGENTS.md", "CLAUDE.md"} and p not in {root/"AGENTS.md", root/"CLAUDE.md"}:
        if ".agents" not in parts:
            dupes.append(str(p))
            
    # Check bin/ non-symlinks
    if top_dir == "bin" and len(parts) == 2:
        if not p.is_symlink() and filename not in core_runner_files and filename != "__pycache__" and filename.lower() != "readme.md":
            non_symlink_bin.append(str(p))

    # Check misplaced scripts
    ext = p.suffix.lower()
    is_script = ext in (".sh", ".py", ".bash", ".zsh") or (not ext and os.access(p, os.X_OK) and not p.is_symlink())
    if is_script and top_dir not in subsystem_dirs and top_dir not in ("bin", "scripts", "tests"):
        # Don't flag root level markdown files
        if ext != ".md":
            misplaced_scripts.append(str(p))

    # Check internal duplication in workspace scripts
    if is_script and not p.is_symlink() and top_dir in subsystem_dirs:
        try:
            content = p.read_text(errors="ignore")
            if ext == ".py":
                import ast
                tree = ast.parse(content)
                # Only compare function names among direct siblings within the
                # same scope (module/function/class body) — ast.walk() alone
                # would also match same-named nested closures in different
                # parent scopes, which is legal Python, not a duplicate.
                for scope in ast.walk(tree):
                    body = getattr(scope, "body", None)
                    if not isinstance(body, list):
                        continue
                    seen_names = set()
                    for node in body:
                        if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):
                            if node.name in seen_names:
                                issue("warning", "internal_script_duplication", f"Script '{p.relative_to(root)}' contains duplicate definition for function '{node.name}' (line {node.lineno}).", p)
                            seen_names.add(node.name)
        except Exception:
            pass
        
    # Check misplaced configs
    is_config = ext in (".json", ".yaml", ".yml", ".toml") and ("config" in filename.lower() or "policy" in filename.lower() or "weights" in filename.lower())
    if is_config and filename != "opencode.json":
        in_config_dir = any(part in ("config", "router", "adaptive", "settings", "evolution", "mcp", "model_router") for part in parts)
        if not in_config_dir and top_dir not in (".agents", ".claude", ".gstack", ".rtk", ".serena"):
            misplaced_configs.append(str(p))


if dupes:
    issue("info", "duplicate_instruction_files", "Additional AGENTS.md/CLAUDE.md files exist; inspect before consolidating", None)
    suggestions.append({"code": "inspect_duplicates", "paths": dupes[:20]})
    
if non_symlink_bin:
    issue("warning", "non_symlink_bin_file", f"Regular files found in bin/ (expected symlinks only): {', '.join(pathlib.Path(x).name for x in non_symlink_bin)}", None)
    suggestions.append({"code": "convert_bin_to_symlink", "paths": non_symlink_bin[:20]})
    
if misplaced_scripts:
    issue("error", "misplaced_script", f"Scripts found outside canonical subsystem directories: {', '.join(pathlib.Path(x).name for x in misplaced_scripts)}", None)
    suggestions.append({"code": "move_misplaced_scripts", "paths": misplaced_scripts[:20]})
    
if misplaced_configs:
    issue("error", "misplaced_config", f"Configuration files found outside config/ directories: {', '.join(pathlib.Path(x).name for x in misplaced_configs)}", None)
    suggestions.append({"code": "move_misplaced_configs", "paths": misplaced_configs[:20]})
errors = sum(1 for i in issues if i["severity"] == "error")
warnings = sum(1 for i in issues if i["severity"] == "warning")
status = "healthy" if errors == 0 and warnings == 0 else ("repairable" if errors or warnings else "attention")
try:
    previous_health = json.loads(health_path.read_text())
except Exception:
    previous_health = {}
data = {
    "checked_at": datetime.now().astimezone().strftime("%Y-%m-%dT%H:%M:%S%z"),
    "last_doctor_run": datetime.now().astimezone().strftime("%Y-%m-%dT%H:%M:%S%z"),
    "status": status,
    "issue_count": len(issues),
    "error_count": errors,
    "warning_count": warnings,
    "issues": issues,
    "repair_suggestions": suggestions,
    "auto_fixes_applied": int(previous_health.get("auto_fixes_applied", 0)),
    "tools": {"codex": shutil.which("codex"), "claude": shutil.which("claude")},
    "launchd": {
        "configured": launchd_user_plist.exists() or launchd_user_plist.is_symlink(),
        "loaded": loaded,
        "label": launchd_label,
        "plist": str(launchd_user_plist),
    },
}
tmp = health_path.with_suffix(health_path.suffix + ".tmp")
tmp.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")
tmp.replace(health_path)
print(f"Workspace health: {status} ({len(issues)} issues)")
for item in issues[:20]:
    print(f"- {item['severity']}: {item['message']}")
PY

log_maintenance "Doctor ran."

if [ -f "$ROOT/hands/scripts/system_intelligence.py" ]; then
  python3 "$ROOT/hands/scripts/system_intelligence.py" health-update >/dev/null 2>&1 || true
fi
