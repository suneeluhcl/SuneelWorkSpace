#!/bin/bash
# adwi-autoresearch-morning — overnight Adwi autoresearch results briefing
# Shows what Claude improved while you slept.

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
export HOME="/Users/MAC"

WORKSPACE="$HOME/SuneelWorkSpace"
LOG_DIR="$WORKSPACE/logs/autoresearch/adwi"

echo "============================================="
echo "  Adwi Autoresearch Morning Briefing"
echo "  $(date '+%A, %B %-d %Y')"
echo "============================================="
echo ""

# Active sessions
ACTIVE=$(screen -ls 2>/dev/null | grep "adwi-ar-" | awk '{print $1}' || true)
if [ -n "$ACTIVE" ]; then
    echo "ACTIVE SESSIONS (still running):"
    echo "$ACTIVE" | while read -r s; do
        echo "  • $s  →  screen -r $s"
    done
    echo ""
fi

# Results from all adwi-autoresearch branches
cd "$WORKSPACE"

BRANCHES=$(git branch --list "adwi-autoresearch/*" 2>/dev/null | sed 's/^[* ]*//' | sort -r | head -10)

if [ -z "$BRANCHES" ]; then
    echo "No adwi-autoresearch branches found yet."
    echo "Run: adwi-autoresearch-night [N]"
    exit 0
fi

DENYLIST_PATTERNS="adwi/config/.env|secrets/|adwi/infra/docker/n8n-data|obsidian-vault/|adwi/memory.db|adwi/knowledge.db|adwi/training-data/|\.db$|\.sqlite$"

for BRANCH in $BRANCHES; do
    TAG="${BRANCH#adwi-autoresearch/}"
    echo "──────────────────────────────────────────────"
    echo "Branch: $BRANCH"

    # Denylist path audit — warn if any commit on this branch touched restricted paths
    DENYLIST_HITS=$(git diff --name-only "main...${BRANCH}" 2>/dev/null \
        | grep -E "$DENYLIST_PATTERNS" || true)
    if [ -n "$DENYLIST_HITS" ]; then
        echo "  ⚠ WARNING: branch touched denylisted paths — review before merging:"
        echo "$DENYLIST_HITS" | while read -r f; do printf "      %s\n" "$f"; done
    fi

    TSV=$(git show "${BRANCH}:adwi/autoresearch-results.tsv" 2>/dev/null || true)
    if [ -z "$TSV" ]; then
        echo "  No results yet (session may still be setting up)"
        # Show recent commits on the branch anyway
        COMMITS=$(git log "main..${BRANCH}" --oneline 2>/dev/null | head -5)
        if [ -n "$COMMITS" ]; then
            echo "  Recent commits:"
            echo "$COMMITS" | while read -r line; do echo "    $line"; done
        fi
        continue
    fi

    TOTAL=$(echo "$TSV"    | tail -n +2 | wc -l | tr -d ' ')
    KEPT=$(echo "$TSV"     | tail -n +2 | awk -F'\t' '$8=="keep"'    | wc -l | tr -d ' ')
    DISCARDED=$(echo "$TSV"| tail -n +2 | awk -F'\t' '$8=="discard"' | wc -l | tr -d ' ')
    CRASHED=$(echo "$TSV"  | tail -n +2 | awk -F'\t' '$8=="crash"'   | wc -l | tr -d ' ')

    # Baseline and best NLU pass counts (column 2 and 3)
    BASE_NLU=$(echo "$TSV"  | tail -n +2 | awk -F'\t' 'NR==1 {print $2"/"$3}')
    BEST_NLU=$(echo "$TSV"  | tail -n +2 | awk -F'\t' '$8=="keep" {best=$2; tot=$3} END {print best"/"tot}')
    BEST_DESC=$(echo "$TSV" | tail -n +2 | awk -F'\t' '$8=="keep" {desc=$9} END {print desc}')

    echo "  Experiments: $TOTAL total  ($KEPT kept / $DISCARDED discarded / $CRASHED crashed)"
    if [ -n "$BASE_NLU" ] && [ -n "$BEST_NLU" ]; then
        echo "  NLU tests:   $BASE_NLU (baseline)  →  $BEST_NLU (best kept)"
        [ -n "$BEST_DESC" ] && echo "  Best change: $BEST_DESC"
    fi

    # Changes vs main
    COMMITS_AHEAD=$(git rev-list "main..${BRANCH}" --count 2>/dev/null || echo "?")
    FILES_CHANGED=$(git diff --stat "main...${BRANCH}" 2>/dev/null | tail -1 || true)
    echo "  Commits ahead of main: $COMMITS_AHEAD"
    [ -n "$FILES_CHANGED" ] && echo "  Files changed: $FILES_CHANGED"

    echo ""
    echo "  Recent experiments:"
    echo "$TSV" | tail -n +2 | tail -5 | while IFS=$'\t' read -r commit nlu_p nlu_t docs_p docs_t sec_p sec_t status desc; do
        ICON="✓"
        [ "$status" = "discard" ] && ICON="✗"
        [ "$status" = "crash" ]   && ICON="!"
        printf "    %s [%s] NLU=%s/%s docs=%s/%s  %s\n" \
            "$ICON" "$commit" "$nlu_p" "$nlu_t" "$docs_p" "$docs_t" "$desc"
    done
    echo ""

    # Log file
    LOG_FILE="$LOG_DIR/${TAG}.log"
    if [ -f "$LOG_FILE" ]; then
        echo "  Log: $LOG_FILE  ($(wc -l < "$LOG_FILE") lines)"
    fi
    echo ""
done

echo "============================================="
echo "To review a branch diff:"
echo "  git diff main...adwi-autoresearch/<tag>"
echo "To cherry-pick a good commit to main:"
echo "  git cherry-pick <commit-hash>"
echo "To delete a branch after review:"
echo "  git branch -d adwi-autoresearch/<tag>"
